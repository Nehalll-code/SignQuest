<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera permission for MediaPipe hand detection -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature android:name="android.hardware.camera.ar" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SignQuest">

        <!-- ARCore Option -->
        <meta-data
            android:name="com.google.ar.core"
            android:value="optional" />

        <!-- User Select (NEW Launcher) -->
        <activity
            android:name=".ui.UserSelectActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Profile / Login Screen (no longer launcher) -->
        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Detection / Camera Screen -->
        <activity
            android:name=".ui.DetectionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- World Map Screen -->
        <activity
            android:name=".ui.WorldMapActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.ComprehensionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.ParentDashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.StoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.ARMapActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Level Detail Screen -->
        <activity
            android:name=".ui.LevelDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>
