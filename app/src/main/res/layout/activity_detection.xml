<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- CameraX Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Hand landmark overlay drawn on top of camera -->
    <com.signquest.app.ui.HandOverlayView
        android:id="@+id/handOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar: title + back -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#80000000">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:padding="8dp"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvDetectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/detection_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <!-- Spacer to balance the back button -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Reference instruction card (floating above camera) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="72dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#E6FFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/tvTargetReference"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="@color/colorPrimary"
                android:textSize="56sp"
                android:textStyle="bold"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tvInstructions"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="📖 Instructions will appear here"
                android:textColor="#2D3436"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom card: detected sign display -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp">

            <!-- Target letter to sign -->
            <TextView
                android:id="@+id/tvTargetLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show me the sign:"
                android:textColor="#636E72"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvTargetLetter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="#6C63FF"
                android:textSize="64sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <!-- Detected sign result -->
            <TextView
                android:id="@+id/tvDetectedSign"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detection_hint"
                android:textColor="#2D3436"
                android:textSize="16sp"
                android:layout_marginTop="8dp" />

            <!-- Confidence bar -->
            <ProgressBar
                android:id="@+id/progressConfidence"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_bar" />

            <!-- Done button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="✅ Done!"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6C63FF"
                android:visibility="gone"
                app:cornerRadius="20dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
